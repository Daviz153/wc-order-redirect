<?xml version="1.0"?>
<ruleset name="WC Order Redirect">
    <description>WordPress Coding Standards for WC Order Redirect plugin</description>

    <!-- 검사 대상 -->
    <file>wc-order-redirect.php</file>
    <file>includes/</file>
    <file>uninstall.php</file>

    <!-- 제외 대상 -->
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>

    <!-- PHP 최소 버전 -->
    <config name="testVersion" value="8.1-"/>
    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- WordPress-Core 기반 (Extra는 단축 배열 금지 등 과도한 규칙 포함) -->
    <rule ref="WordPress-Core"/>

    <!-- 외부 URL 리다이렉트가 플러그인 핵심 기능 — wp_safe_redirect() 경고 제외 -->
    <rule ref="WordPress.Security.SafeRedirect">
        <exclude-pattern>includes/class-wc-order-redirect\.php</exclude-pattern>
    </rule>

    <!-- WC 설정·메타박스: nonce를 WC가 검증 (phpcs:ignore 주석과 동일한 이유) -->
    <rule ref="WordPress.Security.NonceVerification">
        <exclude-pattern>includes/class-wc-order-redirect-settings\.php</exclude-pattern>
        <exclude-pattern>includes/class-wc-order-redirect-meta\.php</exclude-pattern>
    </rule>

    <!-- 파일 레벨 주석 불필요 (플러그인 헤더로 충분) -->
    <rule ref="Squiz.Commenting.FileComment">
        <severity>0</severity>
    </rule>
</ruleset>
